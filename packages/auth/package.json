{
  "name": "@eslee/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./env": "./src/env.ts"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "with-env": "dotenv -e ../../.env --",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@eslee/db": "workspace:*",
    "@t3-oss/env-nextjs": "^0.11.1",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "next": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslee/tsconfig": "workspace:*",
    "@types/node": "catalog:node",
    "dotenv-cli": "catalog:",
    "typescript": "catalog:"
  }
}
