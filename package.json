{
  "name": "@eslee-io/root",
  "private": true,
  "engines": {
    "node": ">=20.16.0",
    "pnpm": "^10.30.0"
  },
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:generate": "turbo -F @eslee/db db:generate",
    "db:migrate": "turbo -F @eslee/db db:migrate",
    "db:push": "turbo -F @eslee/db db:push",
    "db:studio": "turbo -F @eslee/db db:studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @eslee/www...",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "start": "turbo run start",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "generate:importmap": "pnpm -F @eslee/cms  generate:importmap",
    "generate:types": "pnpm -F @eslee/cms -F @eslee/payload generate:types"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@turbo/gen": "^2.1.3",
    "dotenv": "^17.3.1",
    "pg": "^8.16.3",
    "turbo": "^2.1.3",
    "typescript": "catalog:"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "*",
        "react-dom": "*"
      }
    }
  }
}
